# Groner CRM — credenciais da API (nunca commitar o .env real)
# Gere token longo: POST https://{tenant}.api.groner.app/api/Conta/GerarToken

GRONER_TENANT=mhzenergiasolar
GRONER_TOKEN=seu-token-jwt-aqui

# Pré-venda — cadastro automático quando cliente não veio da busca Groner
GRONER_ORIGEM_PRE_VENDA_ID=35
GRONER_TIPO_PROJETO_PRE_VENDA_ID=223

# Opcional: IDs dos campos personalizados (sobrescreve config/groner-integracao.json)
# GRONER_CAMPO_KWP_ID=169
# GRONER_CAMPO_QTD_PLACAS_ID=170
# GRONER_CAMPO_PDF_PROPOSTA_ID=171
# GRONER_CAMPO_DESCRICAO_PROPOSTA_ID=172
# GRONER_CAMPO_VALOR_TOTAL_PROPOSTA_ID=173
# GRONER_CAMPO_VALOR_TOTAL_SISTEMA_ID=174
# GRONER_CAMPO_PLANO_ID=175
# GRONER_CAMPO_MENSALIDADE_ID=176
# GRONER_ABA_DINAMICA_ID=2

# Porta da API local (npm run dev:api)
API_PORT=3001
