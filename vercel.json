{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/groner/upload-pdf.js": {
      "maxDuration": 120,
      "memory": 1024
    },
    "api/groner/sincronizar-proposta.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!assets|api|.*\\..*).+)", "destination": "/index.html" }
  ]
}
