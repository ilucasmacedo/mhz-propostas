{
  "meta": {
    "versao": "1.0",
    "atualizado_em": "2026-05-29",
    "descricao": "Fonte única de dados para cálculos de precificação solar MHZ",
    "fonte_codigo": "src/pricing.js",
    "unidade_moeda": "BRL",
    "unidade_potencia": "kWp",
    "unidade_distancia": "km"
  },

  "entradas": [
    {
      "codigo": "kwp",
      "nome": "Potência da usina",
      "tipo": "decimal",
      "unidade": "kWp",
      "obrigatorio": true,
      "default": 8.5,
      "min": 0.1,
      "max": 500,
      "campo_ui": "usina-kwp",
      "usado_em": ["mensalidade", "faixa_kwp"]
    },
    {
      "codigo": "plano",
      "nome": "Plano selecionado",
      "tipo": "enum",
      "opcoes": ["NENHUM", "ACESSO", "PADRAO", "PREMIUM"],
      "default": "NENHUM",
      "campo_ui": "plano-selecionado",
      "usado_em": ["mensalidade", "desconto_avulso"]
    },
    {
      "codigo": "distancia_km",
      "nome": "Distância usina → base",
      "tipo": "decimal",
      "unidade": "km",
      "obrigatorio": true,
      "default": 35,
      "campo_ui": "usina-distancia",
      "usado_em": ["deslocamento"]
    },
    {
      "codigo": "qtd_placas",
      "nome": "Quantidade de placas",
      "tipo": "inteiro",
      "obrigatorio": false,
      "default": 16,
      "campo_ui": "usina-placas",
      "usado_em": ["servico_MANUT_PREVENTIVA"]
    },
    {
      "codigo": "valor_contrato",
      "nome": "Valor do contrato (seguro)",
      "tipo": "decimal",
      "unidade": "R$",
      "obrigatorio": false,
      "default": 0,
      "campo_ui": "usina-contrato",
      "usado_em": ["servico_SEGURO"]
    },
    {
      "codigo": "valor_investimento",
      "nome": "Valor do investimento da usina",
      "tipo": "decimal",
      "unidade": "R$",
      "obrigatorio": false,
      "default": 0,
      "campo_ui": "usina-investimento",
      "usado_em": ["taxa_investimento"]
    },
    {
      "codigo": "servicos_selecionados",
      "nome": "Serviços avulsos selecionados",
      "tipo": "lista",
      "obrigatorio": false,
      "default": [],
      "campo_ui": "servico-check",
      "usado_em": ["servicos_avulsos"]
    },
    {
      "codigo": "tem_plano_ativo",
      "nome": "Cliente já possui plano ativo",
      "tipo": "booleano",
      "obrigatorio": false,
      "default": false,
      "campo_ui": null,
      "usado_em": ["desconto_avulso"],
      "observacao": "Não exposto na UI atual; desconto vem da seleção de Padrão/Premium"
    },
    {
      "codigo": "percentual_investimento",
      "nome": "Percentual sobre investimento",
      "tipo": "decimal",
      "unidade": "%",
      "obrigatorio": false,
      "default": 4.5,
      "min": 4,
      "max": 5,
      "campo_ui": null,
      "usado_em": ["taxa_investimento"],
      "observacao": "Fixo no código; futuro módulo admin"
    },
    {
      "codigo": "incluir_deslocamento_global",
      "nome": "Incluir deslocamento como item global",
      "tipo": "booleano",
      "obrigatorio": false,
      "default": true,
      "campo_ui": null,
      "usado_em": ["deslocamento"]
    }
  ],

  "constantes": {
    "sem_plano": "NENHUM",
    "validade_proposta_dias": 15,
    "percentual_investimento_padrao": 4.5,
    "percentual_investimento_min": 4,
    "percentual_investimento_max": 5,
    "raio_base_km": 50,
    "kwp_maximo_automatico": 50,
    "kwp_maximo_formulario": 500,
    "distancia_maxima_automatica": 600,
    "reajuste_deslocamento_multiplicador": 1.6,
    "reajuste_deslocamento_percentual": 60,
    "casas_decimais_moeda": 2,
    "numero_proposta_seq_min": 1000,
    "numero_proposta_seq_max": 9999
  },

  "limites": [
    {
      "codigo": "KWP_ACIMA_50",
      "condicao": "kwp > 50",
      "valor_limite": 50,
      "efeito": "Mensalidade sob consulta",
      "bloqueia_calculo": true
    },
    {
      "codigo": "DISTANCIA_ACIMA_600",
      "condicao": "distancia_km > 600",
      "valor_limite": 600,
      "efeito": "Taxa R$ 4,00/km (mesma faixa 401+)",
      "bloqueia_calculo": false
    },
    {
      "codigo": "DESLOCAMENTO_ISENTO",
      "condicao": "distancia_km <= 50",
      "valor_limite": 50,
      "efeito": "Deslocamento = R$ 0",
      "bloqueia_calculo": false
    }
  ],

  "planos": {
    "ACESSO": {
      "codigo": "ACESSO",
